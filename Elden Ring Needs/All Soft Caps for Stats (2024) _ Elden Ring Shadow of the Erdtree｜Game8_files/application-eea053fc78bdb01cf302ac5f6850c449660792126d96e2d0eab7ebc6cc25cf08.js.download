document.addEventListener("DOMContentLoaded", function () {
  var feedbackModal = document.getElementById("js-feedback-modal");
  if (!feedbackModal) return;
  var feedbackForm = document.getElementById("js-feedback-form");
  var feedbackTextarea = document.getElementById("js-feedback-textarea");
  var feedbackTextareaPreview = document.getElementById("js-feedback-textarea-preview");
  var confirmFeedbackBtn = document.getElementById("js-feedback-confirm-btn");
  var feedbackConfirm = document.getElementById("js-feedback-confirm");
  var confirmFeedback = function confirmFeedback() {
    var feedback_text = feedbackTextarea.value;
    if (!feedback_text) return alert(I18n.t('js.shared.archive_feedback.alert_1'));
    feedbackTextareaPreview.innerText = feedback_text;
    feedbackForm.style.display = "none";
    feedbackConfirm.style.display = "block";
  };
  confirmFeedbackBtn.addEventListener("click", function () {
    return confirmFeedback();
  });
  var backFeedbackBtn = document.getElementById("js-feedback-back");
  backFeedbackBtn.addEventListener("click", function () {
    feedbackForm.style.display = "block";
    feedbackConfirm.style.display = "none";
  });
  var submitFeedbackBtn = document.getElementById("js-feedback-submit");
  submitFeedbackBtn.addEventListener("click", function (e) {
    e.preventDefault();
    window.grecaptcha.ready(function () {
      window.grecaptcha.execute('6LctfpklAAAAAHCYf_OfWPzzOywr7TBLHzOjq9AY', {
        action: 'submit'
      }).then(function (token) {
        var body = JSON.stringify({
          feedback: {
            body: feedbackTextarea.value,
            archive_id: gon.archive_id,
            game_id: gon.game_id,
            url: location.href,
            title: gon.title || gon.forum_title,
            recaptcha_token: token // reCAPTCHAトークンを追加
          },
          archive_id: gon.archive_id
        });
        fetchJSON("/api/feedback", {
          method: "post",
          referrer: self.location.origin,
          headers: {
            "Content-Type": "application/json"
          },
          body: body
        }).then(function () {
          alert(I18n.t('js.shared.archive_feedback.alert_2'));
          feedbackForm.style.display = "block";
          feedbackConfirm.style.display = "none";
          feedbackTextarea.value = "";
          MicroModal.close("js-feedback-modal");
        });
      });
    });
  }, {
    once: true
  });
});
