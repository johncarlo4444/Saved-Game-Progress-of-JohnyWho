window.addEventListener('DOMContentLoaded', function () {
  var elements = document.querySelectorAll(".js-archive-open-image-modal");
  if (!elements.length) return;
  var currentIndex = 0;
  var updateModal = function updateModal(element) {
    var _element$dataset = element.dataset,
      imageUrl = _element$dataset.imageUrl,
      archiveUrl = _element$dataset.archiveUrl;
    var img = element.querySelector('img');
    var modalImage = document.querySelector('#js-archive-open-image');
    var buttonLink = document.querySelector('#js-archive-open-image-button');
    var prevButton = document.querySelector('#prev-button');
    var nextButton = document.querySelector('#next-button');
    modalImage.src = imageUrl;
    buttonLink.style.display = archiveUrl ? 'block' : 'none';
    if (archiveUrl) {
      buttonLink.href = archiveUrl;
      buttonLink.innerHTML = img.alt ? "\u25B6\uFE0EView article for ".concat(img.alt) : '▶︎View article for this image';
    }
    prevButton.style.display = currentIndex > 0 ? 'block' : 'none';
    nextButton.style.display = currentIndex < elements.length - 1 ? 'block' : 'none';
  };
  var handleModal = function handleModal(index) {
    currentIndex = index;
    updateModal(elements[currentIndex]);
  };
  document.addEventListener('click', function (event) {
    var clickedElement = event.target.closest('.js-archive-open-image-modal');
    if (clickedElement) {
      event.preventDefault();
      var index = Array.from(elements).indexOf(clickedElement);
      if (index !== -1) handleModal(index);
    }
  });
  var modalContent = document.querySelector('#js-archive-open-image-modal .c-micromodal__content');
  if (modalContent) {
    modalContent.insertAdjacentHTML('beforeend', "\n      <button id=\"prev-button\" class=\"c-micromodal__arrow-button left\" aria-label=\"Previous image\">\n        <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M15 18L9 12L15 6\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n      <button id=\"next-button\" class=\"c-micromodal__arrow-button right\" aria-label=\"Next image\">\n        <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M9 18L15 12L9 6\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n    ");
    document.querySelector('#prev-button').addEventListener('click', function () {
      if (currentIndex > 0) handleModal(currentIndex - 1);
    });
    document.querySelector('#next-button').addEventListener('click', function () {
      if (currentIndex < elements.length - 1) handleModal(currentIndex + 1);
    });
  }
});
