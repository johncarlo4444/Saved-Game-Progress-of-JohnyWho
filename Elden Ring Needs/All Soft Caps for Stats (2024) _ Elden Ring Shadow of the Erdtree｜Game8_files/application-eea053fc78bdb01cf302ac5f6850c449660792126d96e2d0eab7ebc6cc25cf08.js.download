if (gon.game_id === 1147 && document.getElementById('switch_sports/random_title')) {
  window.addEventListener('DOMContentLoaded', function () {
    var titles = gon.random_titles;
    titles.splice(titles.indexOf('db header'), 1);
    generate_title(titles);
  });
  function generate_title(titles) {
    document.getElementById('generate-btn').addEventListener('click', function (e) {
      var first_pick = first_pick_judge(titles);
      var second_pick = titles[Math.floor(Math.random() * titles.length)];
      var first_pick_element = document.getElementById('first_pick');
      var second_pick_element = document.getElementById('second_pick');
      first_pick_element.innerHTML = first_pick;
      second_pick_element.innerText = second_pick;
    });
  }
  function first_pick_judge(titles) {
    var first_pick_result = titles[Math.floor(Math.random() * titles.length)];
    if (first_pick_result === '[None]') {
      return first_pick_judge(titles);
    }
    return first_pick_result;
  }
};
if (gon.game_id === 1201 && document.getElementById('hogwarts_legacy-random_title')) {
  window.addEventListener('DOMContentLoaded', function () {
    var words = gon.random_titles;
    var first_pick = word_split(words, [], 1);
    var second_pick = word_split(words, [], 2);
    generate_title(first_pick, second_pick);
  });
  function word_split(words, picks, col) {
    words.forEach(function (word) {
      switch (col) {
        case 1:
          word[1] === '1' ? picks.push(word) : null;
          break;
        case 2:
          word[2] === '1' ? picks.push(word) : null;
          break;
      }
    });
    return picks;
  }
  function generate_title(first_pick, second_pick) {
    document.getElementById('generate-btn').addEventListener('click', function (e) {
      document.getElementById('first_pick').innerHTML = find_by_word(first_pick, 0);
      document.getElementById('second_pick').innerText = find_by_word(second_pick, 0);
    });
  }
  function find_by_word(words, index) {
    return words[Math.floor(Math.random() * words.length)][index];
  }
};
if (gon.game_id === 1239 && document.getElementById('starfiled/random_title')) {
  window.addEventListener('DOMContentLoaded', function () {
    var titles = gon.random_titles;
    titles.splice(titles.indexOf('db header'), 1);
    generate_title(titles);
  });
  function generate_title(titles) {
    document.getElementById('generate-btn').addEventListener('click', function (e) {
      var first_pick = titles[Math.floor(Math.random() * titles.length)];
      var first_pick_element = document.getElementById('first_pick');
      first_pick_element.innerHTML = first_pick;
    });
  }
};


document.addEventListener("DOMContentLoaded", function () {
  var moveTables = document.querySelectorAll('.pokemon_move_list');
  if (moveTables.length === 0) return;
  var typeIcons = document.querySelectorAll('.pokemon_move_filter__type--icon');
  var activeTypes = new Set();
  typeIcons.forEach(function (icon) {
    icon.addEventListener('click', function () {
      var type = icon.dataset.type.toLowerCase();
      if (activeTypes.has(type)) {
        activeTypes.delete(type);
        icon.style.opacity = '0.3';
      } else {
        activeTypes.add(type);
        icon.style.opacity = '1';
      }
      filterMoves();
    });
  });
  function filterMoves() {
    moveTables.forEach(function (moveTable) {
      var rows = moveTable.querySelectorAll('tbody tr');
      for (var i = 0; i < rows.length; i++) {
        var row = rows[i];
        var typeCell = row.querySelector('td[data-type]');
        if (typeCell) {
          var moveType = typeCell.dataset.type.toLowerCase();
          var shouldShow = activeTypes.size === 0 || activeTypes.has(moveType);
          row.style.display = shouldShow ? '' : 'none';

          // 説明行の処理（次の行がある場合）
          if (i + 1 < rows.length) {
            var nextRow = rows[i + 1];
            if (nextRow.querySelector('td[colspan]')) {
              nextRow.style.display = shouldShow ? '' : 'none';
              i++; // 説明行をスキップ
            }
          }
        }
      }
    });
  }
});
document.addEventListener("DOMContentLoaded", function () {
  if (document.getElementsByClassName('pokedex')[0]) {
    var attribute = [];
    var search_target = document.getElementsByClassName('pokedex')[0].nextElementSibling.nextElementSibling.querySelectorAll('.Type_cell');
    Array.from(document.querySelectorAll('.pokedex__type--icon')).forEach(function (e) {
      var icon = e;
      e.addEventListener('click', function () {
        console.log(getComputedStyle(icon).opacity);
        if (getComputedStyle(icon).opacity === '1') {
          pokemon_search_reset(search_target, icon, attribute);
        } else {
          pokemon_search(search_target, icon, attribute);
        }
      });
    });
  }
  function pokemon_search_reset(search_target, icon, attribute) {
    icon.style.opacity = '0.3';
    attribute.splice(attribute.indexOf(icon.dataset.type), 1);
    console.log(attribute);
    Array.from(search_target).forEach(function (e, index) {
      var pokemon_attribute = [];
      Array.from(e.getElementsByClassName('a-link')).map(function (e) {
        return pokemon_attribute.push(e.innerText);
      });
      if (index > 0 && pokemon_attribute.sort().join('').toLowerCase().includes(attribute.sort().join(''))) {
        e.parentNode.style.display = '';
      }
    });
  }
  function pokemon_search(search_target, icon, attribute) {
    icon.style.opacity = '1';
    console.log('check');
    attribute.push(icon.dataset.type);
    Array.from(search_target).forEach(function (e, index) {
      var pokemon_attribute = [];
      Array.from(e.getElementsByClassName('a-link')).map(function (e) {
        return pokemon_attribute.push(e.innerText);
      });
      if (index > 0 && pokemon_attribute.sort().join('').toLowerCase().includes(attribute.sort().join(''))) {
        e.parentNode.style.display = '';
      } else if (!e.classList.contains('table_cell')) {
        e.parentNode.style.display = 'none';
      }
    });
  }
});
