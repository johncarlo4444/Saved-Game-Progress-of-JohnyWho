// ========================================
// API通信
// ========================================

function getLoginStatus() {
  return fetch("/api/users/status", {
    method: "GET",
    headers: {
      Accept: "application/json"
    }
  });
}
function getChecks(categoryDbId) {
  return fetch("/api/category_dbs/".concat(categoryDbId, "/checks"), {
    method: "GET",
    headers: {
      Accept: "application/json"
    }
  });
}
function addChecks(categoryDbId, itemIds) {
  return fetch("/api/category_dbs/".concat(categoryDbId, "/checks"), {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Accept: "application/json"
    },
    body: JSON.stringify({
      item_ids: itemIds
    }),
    keepalive: true
  });
}
function removeChecks(categoryDbId, itemIds) {
  return fetch("/api/category_dbs/".concat(categoryDbId, "/checks"), {
    method: "DELETE",
    headers: {
      "Content-Type": "application/json",
      Accept: "application/json"
    },
    body: JSON.stringify({
      item_ids: itemIds
    }),
    keepalive: true
  });
}

