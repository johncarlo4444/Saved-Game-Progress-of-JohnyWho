    document.body.style.top = "-".concat(savedScrollPosition, "px");
    document.body.style.width = '100%';
    document.body.style.overflow = 'hidden';

    // モーダルオープンログを送信
    if (typeof window.sendClickLog === 'function') {
      var logValue = trackNierValue || 'default_header';
      window.sendClickLog('membership_modal_open', logValue);
    }

