document.addEventListener('DOMContentLoaded', function () {
  if (gon.rails_env === 'production') {
    // このファイル内では利用されないが、他のファイルで利用されているためにグローバル設定を残している
    axios.defaults.headers['X-CSRF-TOKEN'] = document.querySelector('meta[name=csrf-token]').getAttribute('content');
    var commonParams = [];
    commonParams.push({
      key: 'device',
      value: gon.device
    });
    if (gon.archive_id) {
      commonParams.push({
        key: 'archive_id',
        value: gon.archive_id
      }, {
        key: 'archive_revision',
        value: gon.archive_revision
      });
    }
    if (gon.game_id) {
      commonParams.push({
        key: 'game_id',
        value: gon.game_id
      });
    }
    if (Cookies.get('_g8usrid')) {
      commonParams.push({
        key: 'user_id',
        value: Cookies.get('_g8usrid')
      });
    }
    if (Cookies.get('_tdim')) {
      commonParams.push({
        key: 'x-tdim',
        value: Cookies.get('_tdim')
      });
    }
    if (Cookies.get('g8_registered')) {
      commonParams.push({
        key: 'g8_registered',
        value: Cookies.get('g8_registered')
      });
    }
    if ([1007, 1039, 1202, 1092, 1152, 1006, 969, 1051, 1002, 1216].includes(gon.game_id) && Cookies.get('column_test')) {
      commonParams.push({
        key: 'column_test',
        value: Cookies.get('column_test')
      });
    }
    commonParams.push({
      key: 'request_id',
      value: request_id
    });
    commonParams.push({
      key: 'request_time',
      value: request_time
    });
    var deliverd_ad_count = document.querySelectorAll('.ad-wrapper > div > div').length;
    commonParams.push({
      key: 'deliverd_ad_count',
      value: deliverd_ad_count
    });
    if (gon.ad_count) {
      commonParams.push({
        key: 'ad_count',
        value: gon.ad_count
      });
    }
    if (document.referrer) {
      var referer = encodeURIComponent(document.referrer);
      commonParams.push({
        key: 'referer',
        value: referer
      });
    }
    if (document.location.href) {
      var current_page = encodeURIComponent(document.location.href);
      commonParams.push({
        key: 'url',
        value: current_page
      });
    }
    var urlWithParams = function urlWithParams(url, params) {
      return "".concat(url, "?").concat(params.map(function (h) {
        return [h.key, h.value].join('=');
