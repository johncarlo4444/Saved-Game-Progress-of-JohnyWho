    var startDateTime = new Date();
    var endDateTime = new Date(parseInt(timer.dataset.date));
    var left = Math.floor((endDateTime - startDateTime) / 1000);
    var doc = '';
    if (left >= 0) {
      var d = Math.floor(left / 60 / 60 / 24);
      var h = Math.floor(left / 60 / 60) % 24;
      var m = Math.floor(left / 60) % 60;
      var s = Math.floor(left) % 60;
