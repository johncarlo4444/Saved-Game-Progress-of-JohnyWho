document.addEventListener('DOMContentLoaded', function () {
  var userIcon = document.querySelector('.js-open-user-drawer');
  var userDrawer = document.querySelector('.p-userDrawer');
  var userDrawerOverlay = document.querySelector('.p-userDrawer__overlay');
  var closeButton = document.querySelector('.js-close-user-drawer');
  var accordions = document.querySelectorAll('.js-accordion');
  var themeDisplayText = document.querySelector('.js-theme-name');
  if (!userIcon || !userDrawer || !userDrawerOverlay) return;

  // ユーザーアイコンクリック時にドロワーを開く
  userIcon.addEventListener('click', function (e) {
    e.preventDefault();
    userDrawer.classList.add('show');
    userDrawerOverlay.classList.add('show');
  });

  // 閉じるボタンクリック時にドロワーを閉じる
  closeButton.addEventListener('click', function () {
    closeUserDrawer();
  });

  // オーバーレイクリック時にドロワーを閉じる
  userDrawerOverlay.addEventListener('click', function () {
    closeUserDrawer();
  });

  // ESCキー押下時にドロワーを閉じる
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && userDrawer.classList.contains('show')) {
      closeUserDrawer();
    }
  });

  // アコーディオンの機能
  accordions.forEach(function (accordion) {
    var trigger = accordion.querySelector('.p-userDrawerListItem__link');
    var content = accordion.querySelector('.p-userDrawerListItem__content');
    trigger.addEventListener('click', function () {
      // 他のアコーディオンを全て閉じる
      accordions.forEach(function (otherAccordion) {
        if (otherAccordion !== accordion) {
          otherAccordion.classList.remove('is-open');
          otherAccordion.querySelector('.p-userDrawerListItem__content').classList.remove('is-open');
        }
      });

      // 現在のアコーディオンを切り替える
      accordion.classList.toggle('is-open');
      content.classList.toggle('is-open');
    });
  });
  function closeUserDrawer() {
    userDrawer.classList.remove('show');
    userDrawerOverlay.classList.remove('show');
    // ドロワーを閉じる時に全てのアコーディオンを閉じる
    accordions.forEach(function (accordion) {
      accordion.classList.remove('is-open');
      accordion.querySelector('.p-userDrawerListItem__content').classList.remove('is-open');
    });
  }

  // テーマ切り替えの機能
  var themeButtons = {
    light: document.querySelector('.js-theme-light'),
    dark: document.querySelector('.js-theme-dark'),
    system: document.querySelector('.js-theme-system')
  };
  var themeDisplayNames = {
    light: 'Light mode',
    dark: 'Dark mode',
    system: 'System default'
  };
  Object.entries(themeButtons).forEach(function (_ref) {
    var _ref2 = _slicedToArray(_ref, 2),
      theme = _ref2[0],
      button = _ref2[1];
    button.addEventListener('click', function (e) {
      e.preventDefault();
      // 全てのテーマボタンからアクティブクラスを削除
      Object.values(themeButtons).forEach(function (btn) {
        btn.parentElement.classList.remove('p-userDrawerSubList__item--active');
      });
      // クリックされたボタンにアクティブクラスを追加
      button.parentElement.classList.add('p-userDrawerSubList__item--active');
      // テーマの表示テキストを更新
      themeDisplayText.textContent = themeDisplayNames[theme];
    });
  });
});
