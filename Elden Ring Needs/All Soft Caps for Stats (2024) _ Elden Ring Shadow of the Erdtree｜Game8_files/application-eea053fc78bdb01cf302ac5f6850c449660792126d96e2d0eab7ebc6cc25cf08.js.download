document.addEventListener("DOMContentLoaded", function () {
  var TARGET_CLASSNAME = "premium-archive-link";
  var TARGET_SELECTOR = "a.".concat(TARGET_CLASSNAME);
  var isTouchDevice = function isTouchDevice() {
    return "ontouchstart" in window || navigator.maxTouchPoints;
  };
  var isLoggedIn = window.gon.is_signed_in;
  if (isLoggedIn) {
    return;
  }
  tippy(TARGET_SELECTOR, {
    /**
     * @param {HTMLElement} link
     */
    content: function content(link) {
      var content = "You can read this article by registering for a free membership.";
      if (isTouchDevice()) {
        /** @type {HTMLElement} */
        var l = link.cloneNode();
        l.innerHTML = "Go to article";
        l.classList.remove(TARGET_CLASSNAME);
        content = "".concat(content, " ").concat(l.outerHTML);

        // MEMO: リンク遷移がタッチで反応しないようにする(タッチデバイスの場合リンクの遷移とツールチップの表示両方が起きる)
        link.removeAttribute("href");
      }
      return content;
    },
    allowHTML: true,
    interactive: isTouchDevice()
  });
});
// プレミアム記事で目次の項目が切れている場合、サインイン用の項目に移動させる
document.addEventListener("DOMContentLoaded", function () {
  var PREMIUM_SIGNUP_PROMPT_ID = "js-premium-signup-prompt";
  var premiumSignupPrompt = document.getElementById(PREMIUM_SIGNUP_PROMPT_ID);
  if (!premiumSignupPrompt) {
    return;
  }
  var indexLinks = Array.from(document.querySelectorAll(".a-outline")).map(function (outline) {
    return Array.from(outline.querySelectorAll("a"));
  }).flat();
  if (indexLinks.length === 0) {
    return;
  }
  indexLinks.forEach(function (link) {
    // MEMO: link.hrefだとフルパスが返ってくる
    var targetHash = link.getAttribute("href");
    if (targetHash.startsWith("#")) {
      var target = document.querySelector(targetHash);
      if (target === null) {
        link.href = "#".concat(PREMIUM_SIGNUP_PROMPT_ID);
      }
    }
  });
});
