window.addEventListener('DOMContentLoaded', function () {
  if (document.getElementsByClassName('table-config')[0]) {
    // header固定、縦スクロール
    table_style_adjustment();

    // 読み込み時に項目を読み取り、checkboxを追加
    load_item_add_checkbox();

    // checkboxクリック時のテーブル操作
    cell_operation();
    allow_operation();

    // アイコンクリック時の開閉
    opening_and_closing();

    // 検索機能
    search_operation();

    // リセット機能
    reset_operation();
  }
});
function table_style_adjustment() {
  Array.from(document.getElementsByClassName('table-config')).forEach(function (e) {
    e.nextElementSibling.style.display = 'block';
    e.nextElementSibling.style.overflow = 'scroll';
    e.nextElementSibling.style.margin = '0';
    e.nextElementSibling.style.marginBottom = '20px';
    if (gon.device === 'pc') {
      e.nextElementSibling.style.height = '800px';
    } else {
      e.nextElementSibling.style.height = '600px';
      e.nextElementSibling.style.width = '100%';
      var navi_icon = document.createElement('i');
      navi_icon.setAttribute('class', 'fa fa-angle-double-right');
      var set_navi_icon = e.appendChild(navi_icon);
      set_navi_icon.style.position = 'absolute';
      set_navi_icon.style.zIndex = '1';
      set_navi_icon.style.right = '4px';
      set_navi_icon.style.top = '318px';
    }
    Array.from(e.nextElementSibling.querySelectorAll('.table_cell')).forEach(function (e) {
      e.style.backgroundColor = '#333';
      e.style.color = '#fff';
      var width = e.dataset.width;
      e.dataset.width = "";
      Array.from(e.parentNode.parentNode.getElementsByClassName("".concat(e.dataset.cell, "_cell"))).forEach(function (e) {
        e.style.width = "".concat(width, "px");
        e.style.minWidth = "".concat(width, "px");
      });
    });
  });
}
function load_item_add_checkbox() {
  var table_cell_set_list = Array.from(document.getElementsByClassName('table-config'));
  var num = 0;
  table_cell_set_list.forEach(function (e) {
    var set_config = e.querySelector('.table-cog');
    var table_cell_list = Array.from(e.nextElementSibling.querySelectorAll('.table_cell'));
    var select = e.querySelector('.table_search_select');
    table_cell_list.forEach(function (e, i) {
      var option = document.createElement('option');
      option.text = e.dataset.cell;
      option.value = e.dataset.cell;
      if (e.dataset.select) {
        option.selected = true;
      }
      select.appendChild(option);
      var li = document.createElement('li');
      li.setAttribute('id', "li_".concat(i));
      var set_li = set_config.appendChild(li);
      var label = document.createElement('label');
      label.setAttribute('class', 'table_cell_select');
      label.setAttribute('for', "".concat(e.dataset.cell, "_").concat(num));
      label.setAttribute('id', "label_".concat(i));
      label.innerHTML = "".concat(e.dataset.cell);
      var set_label = set_li.appendChild(label);
      var input = document.createElement('input');
      input.setAttribute('type', 'checkbox');
      input.setAttribute('id', "".concat(e.dataset.cell, "_").concat(num));
      input.setAttribute('name', "".concat(e.dataset.cell, "_").concat(num));

      // デフォルトでon=表示/off=非表示
      if (e.dataset.default === 'on') {
        input.setAttribute('checked', "checked");
      } else if (e.dataset.default === 'off') {
        Array.from(e.closest('.a-table').getElementsByClassName("".concat(e.dataset.cell, "_cell"))).forEach(function (e) {
          e.style.display = 'none';
          e.dataset.number = "".concat(num);
        });
      }
      if (e.dataset.line === 'off') {
        Array.from(e.closest('.a-table').getElementsByClassName("".concat(e.dataset.cell, "_cell"))).forEach(function (e) {
          e.style.whiteSpace = 'nowrap';
          e.dataset.number = "".concat(num);
        });
      }
      set_label.appendChild(input);
      num++;
    });
  });
}
function cell_operation() {
  var table_cell_select = document.querySelectorAll('.table_cell_select');
  table_cell_select.forEach(function (e) {
    e.addEventListener('click', function () {
      var target_id = e.htmlFor.replace(/_\d*$/, '');
      var checked = e.children[0].checked;
      if (checked) {
        Array.from(e.closest('.table-config').nextElementSibling.getElementsByClassName("".concat(target_id, "_cell"))).forEach(function (e) {
          e.style.display = '';
        });
      } else {
        Array.from(e.closest('.table-config').nextElementSibling.getElementsByClassName("".concat(target_id, "_cell"))).forEach(function (e) {
          e.style.display = 'none';
        });
      }
      cell_not_found(e);
      allow_operation();
    });
  });
}
function opening_and_closing() {
  document.addEventListener('click', function (e) {
    if (!e.target.closest('.c-gameIconList__item_table_setting') && !e.target.closest('.table_cell_select')) {
      Array.from(document.getElementsByClassName('table-cog')).forEach(function (e) {
        e.style.display = 'none';
      });
    } else if (e.target.closest('.c-gameIconList__item_table_setting')) {
      e.target.nextElementSibling.style.display = '';
    }
  });
}
function search_operation() {
  Array.from(document.querySelectorAll('.table_search_word')).forEach(function (e) {
    e.addEventListener('change', function (t) {
      var word = t.target.value.toLowerCase();
      var pattern = /\s+/;
      var regex = new RegExp(pattern);
      var select = t.target.closest('.table-config').querySelector('.table_search_select').value;
      var search_list = t.target.closest('.table-config').nextElementSibling.querySelectorAll(".".concat(select, "_cell"));
      Array.from(search_list).forEach(function (e) {
        // 空検索
        if (word === '' || e.classList.contains('table_cell')) {
          e.parentElement.style.display = '';
          return;
        }
        // 画像用にdata-search部分一致
        if (e.dataset.search && regex.test(word) && JSON.stringify(e.dataset.search.toLowerCase().split(' ').sort()) !== JSON.stringify(word.split(' ').sort())) {
          e.parentElement.style.display = 'none';
        } else if (e.dataset.search && !regex.test(word) && !e.dataset.search.toLowerCase().includes(word)) {
          e.parentElement.style.display = 'none';
          // ない場合はvalueで部分一致
        } else if (e.textContent.replace(/\s+/g, "").match(/^[a-zA-Z0-9!-/:-@¥[-`{-~]*$/)[0] && !e.textContent.toLowerCase().includes(word)) {
          e.parentElement.style.display = 'none';
        } else {
          e.parentElement.style.display = '';
        }
      });
    });
  });
}
function reset_operation() {
  Array.from(document.querySelectorAll('.table_search_reset')).forEach(function (e) {
    e.addEventListener('click', function (e) {
      Array.from(e.target.closest('.table-config').nextElementSibling.rows).forEach(function (e) {
        e.style.display = '';
      });
      e.target.closest('.table-config').querySelector('.table_search_word').value = '';
    });
  });
}
function allow_operation() {
  if (!navigator.userAgent.match(/iPhone|Android.+Mobile/)) {
    return;
  }
  Array.from(document.getElementsByClassName('table-config')).forEach(function (e) {
    var target = Array.from(e.nextElementSibling.querySelectorAll('.table_cell'));
    var width_sum = target.reduce(function (sum, i) {
      return sum + i.clientWidth;
    }, 0);
    var width_base = target[0].closest('.a-table').clientWidth;
    var allow = target[0].closest('.a-table').previousElementSibling.getElementsByClassName('fa-angle-double-right')[0];
    if (width_sum > width_base) {
      allow.style.display = '';
    } else {
      allow.style.display = 'none';
    }
  });
}
function cell_not_found(target) {
  var count = 0;
  Array.from(target.closest('.table-config').nextElementSibling.getElementsByClassName('table_cell')).forEach(function (e) {
    if (e.style.display === '') {
      count++;
    }
  });
  if (count === 0) {
    var p = document.createElement('p');
    p.setAttribute('class', 'cell_not_found c-commentItem__body a-bold');
    p.innerHTML = "No results found.";
    p.style.textAlign = 'center';
    target.closest('.table-config').nextElementSibling.appendChild(p);
  } else if (target.closest('.table-config').nextElementSibling.getElementsByClassName('cell_not_found')[0]) {
    target.closest('.table-config').nextElementSibling.getElementsByClassName('cell_not_found')[0].remove();
  }
};
