  /**
   *
   * @returns {Promise<Response<>>}
   */
  function getLoginStatus() {
    return fetch("/api/users/status", {
      method: "GET",
      headers: {
        Accept: "application/json"
      }
    });
  }

  /**
   * @param {HTMLTableRowElement} rowEl
