function rollbackCheckboxUI(table, recordIds, checked) {
  if (!table || recordIds.length === 0) return;
  rollingBack = true;
  var idSet = new Set(recordIds);
  table.querySelectorAll("tbody tr[data-record-id]").forEach(function (row) {
    if (!idSet.has(String(row.dataset.recordId))) return;
    var cb = row.querySelector("input[type='checkbox']");
    if (cb && cb.checked !== checked) {
      cb.checked = checked;
      cb.dispatchEvent(new Event("change"));
    }
  });
  rollingBack = false;
}
