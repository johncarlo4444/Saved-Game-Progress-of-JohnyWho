document.addEventListener('DOMContentLoaded', function () {
  if (gon.success) {
    alert(gon.success);
  } else if (gon.errors) {
    alert(gon.errors[0]);
  }
  var submit_customers_button = document.getElementById('js-contact-customers-submit');
  if (submit_customers_button) {
    submit_customers_button.addEventListener('click', function (e) {
      e.preventDefault();
      if (validate_contact_form()) {
        if (confirm(I18n.t('js.shared.contact.alert_1'))) {
          document.getElementById('new_contact').submit();
        }
      }
    });
  }
  var submit_business_button = document.getElementById('js-contact-business-submit');
  if (submit_business_button) {
    submit_business_button.addEventListener('click', function (e) {
      e.preventDefault();
      if (validate_contact_form()) {
        console.log('business_submit');
        document.getElementById('new_contact').submit();
      }
    });
  }
});
function validate_contact_form() {
  var contact_type = document.getElementById("contact_contact_type");
  var name = document.getElementById("contact_name");
  var email = document.getElementById("contact_email");
  var company = document.getElementById("contact_company");
  var tel = document.getElementById("contact_tel");
  var content = document.getElementById("contact_content");
  var errors = [];
  if (contact_type && contact_type.value.length === 0) {
    errors.push(I18n.t('js.shared.contact.errors_1'));
  }
  if (company && company.value.length === 0) {
    errors.push(I18n.t('js.shared.contact.errors_5'));
  }
  if (name && name.value.length === 0) {
    errors.push(I18n.t('js.shared.contact.errors_2'));
  }
  if (email && email.value.length === 0) {
    errors.push(I18n.t('js.shared.contact.errors_3'));
  }
  if (tel && tel.value.length === 0) {
    errors.push(I18n.t('js.shared.contact.errors_6'));
  }
  if (content && content.value.length < 10) {
    errors.push(I18n.t('js.shared.contact.errors_4'));
  }
  if (errors.length === 0) {
    return true;
  }
  alert(errors.join('\n'));
  return false;
};
document.addEventListener('DOMContentLoaded', function () {
  var feedback_submit = document.getElementById('js_feedback_submit');
  if (!feedback_submit) return;
  feedback_submit.addEventListener("click", function () {
    var feedback_url = document.getElementById('feedback_url');
    var feedback_content = document.getElementById('feedback_content').value;
    var attr = feedback_url.value.match(/(https?:\/\/[^/]+\/)(.*\/)(\d+)/);
    if (attr === null || isNaN(attr[3])) {
      alert(I18n.t('js.shared.feedback.alert_1'));
      return;
    }
    var token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
    var formData = new FormData();
    formData.append('feedback[body]', feedback_content);
    formData.append('feedback[url]', feedback_url.value);
    formData.append('feedback[archive_id]', attr[3]);
    fetchJSON('/api/feedback', {
      method: 'POST',
      referrer: self.location.origin,
      headers: {
        'X-CSRF-Token': token
      },
      body: formData
    }).then(function (res) {
      if (res.ok) {
        alert(I18n.t('js.shared.feedback.alert_2'));
        return location.href = '/contacts';
      } else {
        alert(I18n.t('js.shared.feedback.alert_2'));
        return location.href = '/contacts';
      }
    });
  });
});
document.addEventListener("DOMContentLoaded", function () {
  // table内のvideoタグを全て選択
  var videos = document.querySelectorAll('table video');
  if (videos.length === 0) {
    return;
  }

  // 高さを'auto'に設定
  for (var i = 0; i < videos.length; i++) {
    videos[i].style.height = 'auto';
  }
});
