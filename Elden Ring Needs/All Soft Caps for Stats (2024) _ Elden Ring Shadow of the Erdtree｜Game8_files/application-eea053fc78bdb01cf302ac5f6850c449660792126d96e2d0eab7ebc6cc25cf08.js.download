// DOMからツリー構造を抽出する
// 戻り値：[{ parent: h3, children: [ul, h4, ...] }, ...]
// 先頭要素はparent: null
function extractTreeStructuresFromDOM(menuElement) {
  if (menuElement === null) {
    return [];
  }

  // 階層の親となるroot, h3, h4で入れ物を作っておく
  var rootGroup = {
    parent: null,
    children: []
  };
  var result = [rootGroup];
  Array.from(menuElement.childNodes).filter(function (node) {
    return node.tagName === 'H3' || node.tagName === 'H4';
  }).forEach(function (node) {
    return result.push({
      parent: node,
      children: []
    });
  });

  // 子となりうる要素のループ
  var indent = 0;
  var currentGroups = [rootGroup,
  // root
  null,
  // h3
  null // h4
  ];
  Array.from(menuElement.childNodes).filter(function (node) {
    return node.nodeType === Node.ELEMENT_NODE;
  }).filter(function (node) {
    return node.tagName === 'H3' || node.tagName === 'H4' || node.tagName === 'UL' || node.tagName === 'P';
  }).forEach(function (node) {
    if (node.tagName === 'H3') {
      indent = 0;
    } else if (node.tagName === 'H4') {
      indent = 1;
    }
    var targetGroup = currentGroups[indent];
    if (targetGroup) {
      targetGroup.children.push(node);
    }
    if (node.tagName === 'H3' || node.tagName === 'H4') {
      indent++;
      currentGroups[indent] = result.find(function (group) {
        return group.parent === node;
      });
    }
  });
  return result;
}

