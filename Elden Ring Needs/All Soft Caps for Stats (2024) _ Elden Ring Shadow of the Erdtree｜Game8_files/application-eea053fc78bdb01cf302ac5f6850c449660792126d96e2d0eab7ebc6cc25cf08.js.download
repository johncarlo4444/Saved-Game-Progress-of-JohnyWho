window.addEventListener('DOMContentLoaded', function () {
  // 扱う状態が多いのでグローバル汚染を防ぐ
  (function () {
    // デフォルトの回答
    var DEFAULT_ANSWER = "0,0,0,0,0,0";

    // 質問ID(≒ステップ)からフォームを取得する関数
    var questionMap = function questionMap(questionId) {
      switch (questionId) {
        case 0:
          return document.nps_survey_form.advertisement;
        case 1:
          return document.nps_survey_form.quality;
        case 2:
          return document.nps_survey_form.usability;
        case 3:
          return document.nps_survey_form.board;
        case 4:
          return document.nps_survey_form.design;
        default:
          return null;
      }
    };

    // ドロワー制御
    var surveyDrawer = document.getElementsByClassName('drawer_survey')[0];
    if (!surveyDrawer) return;

    // モーダル制御
    var modal = document.getElementsByClassName('survey_modal')[0];
    var closeButtons = document.getElementsByClassName('survey_modal__close');
    var closeLink = document.getElementsByClassName('survey_modal__close-link')[0];
    var closeButtonDone = document.getElementsByClassName('survey_modal__close-done')[0];
    var drawerBadge = document.getElementsByClassName('l-fixedTableOfContents__notify_badge')[0];
    var beeBadge = document.getElementsByClassName('drawer_survey--item__bee--badge')[0];
    var top = document.getElementsByClassName('survey_modal_top')[0];
    var step1 = document.getElementsByClassName('survey_modal_step1')[0];
    var step2 = document.getElementsByClassName('survey_modal_step2')[0];
    var step3 = document.getElementsByClassName('survey_modal_step3')[0];
    var step4 = document.getElementsByClassName('survey_modal_step4')[0];
    var step5 = document.getElementsByClassName('survey_modal_step5')[0];
    var step6 = document.getElementsByClassName('survey_modal_step6')[0];
    var end = document.getElementsByClassName('survey_modal_end')[0];
    var advertisement = document.nps_survey_form.advertisement;
    var quality = document.nps_survey_form.quality;
    var usability = document.nps_survey_form.usability;
    var design = document.nps_survey_form.design;
    var board = document.nps_survey_form.board;

    // モーダルの状態をリセット
    var clearModalTransition = function clearModalTransition() {
      top.classList.remove('modal_display_none');
      step1.classList.add('modal_display_none');
      step2.classList.add('modal_display_none');
      step3.classList.add('modal_display_none');
      step4.classList.add('modal_display_none');
      step5.classList.add('modal_display_none');
      step6.classList.add('modal_display_none');
    };
    // フォームの内容をリセット
    var clearFormValues = function clearFormValues() {
      document.nps_survey_form.answer.value = "";
      advertisement.value = DEFAULT_ANSWER;
      quality.value = DEFAULT_ANSWER;
      usability.value = DEFAULT_ANSWER;
      design.value = DEFAULT_ANSWER;
      board.value = DEFAULT_ANSWER;
      deactivateDetails();
      setCurrentStep(0);
      Array.from(document.getElementsByClassName('survey_modal__navigation--next')).forEach(function (nextButton) {
        nextButton.classList.remove('active');
      });
    };

    // モーダルを開くイベント
    surveyDrawer.addEventListener('click', function (e) {
      // モーダルを開く
      modal.classList.add('active');

      // 赤バッジを消す
      var expireDate = new Date();
      expireDate.setDate(expireDate.getDate() + 15);
      Cookies.set('hide_nps_survey_badge', '1', {
        expires: expireDate,
        path: '/'
      });
      fetch('/api/nps_survey/hide_badge', {
        method: 'POST'
      });
      if (drawerBadge) {
        drawerBadge.remove();
      }
      if (beeBadge) {
        beeBadge.remove();
      }
    });
    // モーダルを閉じるイベント
    Array.from(closeButtons).forEach(function (closeButton) {
      closeButton.addEventListener('click', function (e) {
        clearModalTransition();
        modal.classList.remove('active');
        clearFormValues();
      });
    });
    // モーダルを閉じるイベント
    closeLink.addEventListener('click', function (e) {
      clearModalTransition();
      modal.classList.remove('active');
      clearFormValues();
    });
    // 完了後モーダルを閉じるイベント
    closeButtonDone.addEventListener('click', function (e) {
      modal.classList.remove('active');
    });

    // ステップの制御
    var getCurrentStep = function getCurrentStep() {
      return parseInt(document.nps_survey_form.step.value);
    };
    var setCurrentStep = function setCurrentStep(step) {
      document.nps_survey_form.step.value = step;
    };

    // モーダル内遷移の制御
    var startButton = document.getElementsByClassName('survey_modal_top__start')[0];
    var backButtons = document.getElementsByClassName('survey_modal__navigation--back');
    var nextButtons = document.getElementsByClassName('survey_modal__navigation--next');
    var sendButton = document.getElementsByClassName('survey_modal__navigation--send')[0];
    var shouldActivateNextButton = function shouldActivateNextButton() {
      var currentStep = getCurrentStep();
      var details = getDetails(questionMap(currentStep - 1));
      return !details.includes('0');
    };
    var modalBack = function modalBack() {
      if (getCurrentStep() === 1) {
        top.classList.remove('modal_display_none');
        step1.classList.add('modal_display_none');
      } else {
        var currentStep = document.getElementsByClassName("survey_modal_step".concat(getCurrentStep()))[0];
        var backStep = document.getElementsByClassName("survey_modal_step".concat(getCurrentStep() - 1))[0];
        currentStep.classList.add('modal_display_none');
        backStep.classList.remove('modal_display_none');
      }
      setCurrentStep(getCurrentStep() - 1);
    };
    var modalNext = function modalNext() {
      if (!shouldActivateNextButton()) return;
