// 登録リンクの URL を組み立て直す（純粋関数。テスト可能なようリスナ外に定義）
// signUpQueryParam の utm_* は既存値を尊重し、計測の上書きが起きないようにする
function updateRegistrationLink(registrationLink, utmMedium, signUpQueryParam) {
  if (!registrationLink) return;
  var url = new URL('/users/sign_up', window.location.origin);
  url.searchParams.set('utm_source', 'game8');
  url.searchParams.set('utm_medium', utmMedium || 'default');
  url.searchParams.set('utm_campaign', 'signup_click');
  url.searchParams.set('utm_content', 'membership_modal');
  if (signUpQueryParam) {
    signUpQueryParam.forEach(function (value, key) {
      // utm_* は呼び出し側で上書きされないよう、既存キーがあればスキップ
      if (!url.searchParams.has(key)) {
        url.searchParams.set(key, value);
      }
    });
  }
  registrationLink.href = url.toString();
}

// features テーブルの並び替え（data-category / data-feature-key を頼りに DOM 並び替え）。
// highlightFeatures: 各カテゴリの先頭に持ってくる feature key（配列順がそのまま表示順）。
// categoryOrder: 描画するカテゴリの並び（先頭が table の先頭）。
function applyHighlights(modal, highlightFeatures, categoryOrder) {
  // ★/--highlight クラス/display を初期状態に戻す（featureItem 自体の並び順は戻さない）。
  // 連続呼び出しで順序が崩れないことは呼び出し側の resetModalContent（DOM 丸ごと差し戻し）に依存。
  modal.querySelectorAll('.featureName__star').forEach(function (el) {
    return el.remove();
  });
  modal.querySelectorAll('.featureItem--highlight').forEach(function (el) {
    el.classList.remove('featureItem--highlight');
  });
  modal.querySelectorAll('.featureCategory').forEach(function (el) {
    el.style.display = '';
  });
  modal.querySelectorAll('.featureItem').forEach(function (el) {
    el.style.display = '';
  });
  var table = modal.querySelector('.membersFeatureTable');
  if (!table) return;

  // カテゴリ順入れ替え
  categoryOrder.forEach(function (category) {
    var categoryEl = table.querySelector(".featureCategory[data-category=\"".concat(category, "\"]"));
    if (categoryEl) table.appendChild(categoryEl);
  });

  // 配列の末尾から処理して先頭に prepend することで、最終的に配列順が DOM 順になる
  highlightFeatures.slice().reverse().forEach(function (featureKey) {
    var itemEl = modal.querySelector(".featureItem[data-feature-key=\"".concat(featureKey, "\"]"));
    if (!itemEl) return;
    itemEl.classList.add('featureItem--highlight');
    var featureNameEl = itemEl.querySelector('dt.featureName, .featureName');
    if (featureNameEl) {
      var star = document.createElement('i');
      star.className = 'fa fa-star featureName__star';
      star.setAttribute('aria-hidden', 'true');
      featureNameEl.insertBefore(star, featureNameEl.firstChild);
    }
    var list = itemEl.parentElement;
    if (list) list.insertBefore(itemEl, list.firstChild);
  });
}
