function handleCtaClick(e) {
  var el = e.target.closest('[data-track-action]');
  if (!el) return;
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'cta_click',
    cta_action: el.dataset.trackAction,
    cta_placement: el.dataset.trackPlacement
  });
}
