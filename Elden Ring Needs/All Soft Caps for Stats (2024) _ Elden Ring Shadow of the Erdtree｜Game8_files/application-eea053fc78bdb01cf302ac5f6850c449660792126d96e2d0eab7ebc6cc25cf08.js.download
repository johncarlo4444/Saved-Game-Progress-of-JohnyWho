document.addEventListener('DOMContentLoaded', function () {
  var gameButtons = document.querySelectorAll('.js-bookmark-toggle');
  console.log("[Bookmark] Found ".concat(gameButtons.length, " bookmark buttons"));

  // 初期表示時の空状態確認と処理
  var initialFavoritesList = document.querySelector('#bookmarks-content .p-userDrawerSubList');
  if (initialFavoritesList) {
    console.log('[Bookmark] Checking initial list state');
    var hasItems = initialFavoritesList.querySelectorAll('.p-userDrawerSubList__item:not(.p-userDrawerSubList__empty)').length > 0;
    if (!hasItems && !initialFavoritesList.querySelector('.p-userDrawerSubList__empty')) {
      console.log('[Bookmark] Initializing empty state message');
      var emptyLi = document.createElement('li');
      emptyLi.className = 'p-userDrawerSubList__item p-userDrawerSubList__empty';
      emptyLi.textContent = 'No bookmarked games';
      initialFavoritesList.appendChild(emptyLi);
    }
    console.log('[Bookmark] Initial list state:', {
      totalItems: initialFavoritesList.children.length,
      hasItems: hasItems,
      hasEmptyMessage: initialFavoritesList.querySelector('.p-userDrawerSubList__empty') !== null
    });
  }

  // お気に入りリストを更新する関数
  function updateFavoritesList(data) {
    console.log('[Bookmark] Starting favorites list update with data:', data);
    var bookmarkAccordion = document.querySelector('#bookmarks-content').parentElement;
    var favoritesList = document.querySelector('#bookmarks-content .p-userDrawerSubList');

    // 必要なDOM要素のチェック
    if (!bookmarkAccordion || !favoritesList) {
      console.warn('[Bookmark] Required DOM elements not found:', {
        bookmarkAccordion: !!bookmarkAccordion,
        favoritesList: !!favoritesList
      });
      return;
    }

    // お気に入りリストの更新
    if (data.is_favorited) {
      console.log('[Bookmark] Adding game to favorites:', data.game.name);

      // 同じゲームが既に存在するかチェック
      var existingGame = favoritesList.querySelector("[data-game-id=\"".concat(data.game.id, "\"]"));
      if (existingGame) {
        console.log('[Bookmark] Game already exists in favorites, skipping addition');
        return;
      }

      // 空の状態メッセージの処理
      var emptyMessage = favoritesList.querySelector('.p-userDrawerSubList__empty');
      if (emptyMessage) {
        console.log('[Bookmark] Removing empty state message');
        emptyMessage.remove();
      }

      // 新しいゲームを追加
      console.log('[Bookmark] Creating new list item for game:', data.game.name);
      var li = document.createElement('li');
      li.className = 'p-userDrawerSubList__item';
      li.dataset.gameId = data.game.id;
      var link = document.createElement('a');
      link.href = "/games/".concat(data.game.directory_name);
      link.textContent = data.game.name;
      li.appendChild(link);
      favoritesList.appendChild(li);
      console.log('[Bookmark] Successfully added new game to favorites:', data.game.name);
    } else {
      console.log('[Bookmark] Removing game from favorites:', data.game.id);
      var gameItems = favoritesList.querySelectorAll("[data-game-id=\"".concat(data.game.id, "\"]"));
      gameItems.forEach(function (gameItem) {
        console.log('[Bookmark] Removing game item:', gameItem.textContent);
        gameItem.remove();
      });

      // 更新時にリストが空になった場合のみ実行
      if (favoritesList.children.length === 0) {
        console.log('[Bookmark] List is empty, adding empty state message');
        var _emptyLi = document.createElement('li');
        _emptyLi.className = 'p-userDrawerSubList__item p-userDrawerSubList__empty';
        _emptyLi.textContent = 'No bookmarked games';
        favoritesList.appendChild(_emptyLi);
      }
    }

    // お気に入り数の更新
    var favoritesCount = bookmarkAccordion.querySelector('.p-userDrawerListItem__count');
    if (favoritesCount) {
      console.log('[Bookmark] Updating count:', {
        from: favoritesCount.textContent,
        to: "".concat(data.total_favorites, " games")
      });
      favoritesCount.textContent = "".concat(data.total_favorites, " games");
      favoritesCount.setAttribute('aria-live', 'polite');
    } else {
      console.warn('[Bookmark] Favorites count element not found');
    }
  }

  // ボタンの状態管理用の関数
  function disableButton(button) {
