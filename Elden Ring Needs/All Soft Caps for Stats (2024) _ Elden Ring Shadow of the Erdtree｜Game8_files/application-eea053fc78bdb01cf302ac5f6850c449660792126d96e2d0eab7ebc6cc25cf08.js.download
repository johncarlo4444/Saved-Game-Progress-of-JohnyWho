      var self = this;
      var fields = ['nameField', 'emailField', 'passwordField', 'passwordConfirmationField'];
      fields.forEach(function (fieldName) {
        self.elements[fieldName].addEventListener('input', function () {
          self.validate();
        });
      });
      this.elements.checkbox.addEventListener('change', function () {
        self.validate();
      });
    }
  }, {
    key: "validate",
    value: function validate() {
      var isValid = this.isFormValid();
      this.elements.submitBtn.disabled = !isValid;
    }
  }, {
    key: "isFormValid",
    value: function isFormValid() {
      var self = this;
      var fields = ['nameField', 'emailField', 'passwordField', 'passwordConfirmationField'];
      var allFieldsFilled = fields.every(function (fieldName) {
        return self.elements[fieldName].value.trim() !== '';
      });
      return allFieldsFilled && this.elements.checkbox.checked;
    }
  }]);
}(); // Initialize on DOM ready
function initRegistrationFormValidator() {
  var validator = new RegistrationFormValidator('.p-registrations__form');
  return validator;
}
document.addEventListener('DOMContentLoaded', initRegistrationFormValidator);
// GeoLocation判定に基づくサイドバー広告表示制御
// data属性から設定値を読み取り、GeoLocation APIで国判定後に広告/フォールバックを切り替える
(function () {
  'use strict';

  function init() {
    var container = document.querySelector('.js-geo-ad-container');
    if (!container) return;
    var config = {
      apiEndpoint: container.dataset.apiEndpoint,
      cacheKey: container.dataset.cacheKey,
      targetCountry: container.dataset.targetCountry
    };
    var fallback = document.querySelector('.js-geo-ad-fallback');
    var cachedData = getCachedData(config.cacheKey);
    if (cachedData) {
      handleResult(cachedData, container, fallback, config.targetCountry);
    } else {
      fetchCountryData(config.apiEndpoint, config.cacheKey).then(function (data) {
        handleResult(data, container, fallback, config.targetCountry);
      });
    }
  }
  function getCachedData(cacheKey) {
    try {
      var cached = localStorage.getItem(cacheKey);
      if (!cached) return null;
      var parsed = JSON.parse(cached);
      if (parsed.cache_until && new Date(parsed.cache_until) < new Date()) {
        localStorage.removeItem(cacheKey);
        return null;
      }
      return parsed;
    } catch (e) {
      return null;
    }
  }
  function setCachedData(cacheKey, data) {
    try {
      localStorage.setItem(cacheKey, JSON.stringify(data));
    } catch (e) {
      // LocalStorage書き込み失敗は無視
    }
  }
  function fetchCountryData(apiEndpoint, cacheKey) {
    return fetch(apiEndpoint, {
      method: 'GET',
      headers: {
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      credentials: 'same-origin'
    }).then(function (response) {
      if (!response.ok) throw new Error('HTTP error: ' + response.status);
      return response.json();
    }).then(function (data) {
      setCachedData(cacheKey, data);
      return data;
    }).catch(function () {
      return {
        country_code: 'UNKNOWN',
        allowed: false
      };
    });
  }
  function handleResult(data, container, fallback, targetCountry) {
    if (data.country_code === targetCountry) {
      container.style.display = 'block';
      if (fallback) fallback.style.display = 'none';
    } else {
      container.style.display = 'none';
      if (fallback) fallback.style.display = 'block';
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
// フィリピン向け採用バナー表示制御
// GeoLocation APIで国判定後、対象国のみバナーを表示する
(function () {
  'use strict';

  function init() {
    var containers = document.querySelectorAll('.js-recruit-banner-container');
    if (containers.length === 0) return;

    // 全コンテナ共通の設定（最初のコンテナから取得）
    var firstContainer = containers[0];
    var config = {
      apiEndpoint: firstContainer.dataset.apiEndpoint,
      cacheKey: firstContainer.dataset.cacheKey,
      targetCountry: firstContainer.dataset.targetCountry
    };
    var cachedData = getCachedData(config.cacheKey);
    if (cachedData) {
      showContainers(cachedData, containers, config.targetCountry);
    } else {
      fetchCountryData(config.apiEndpoint, config.cacheKey).then(function (data) {
        showContainers(data, containers, config.targetCountry);
      });
    }
  }
  function getCachedData(cacheKey) {
    try {
      var cached = localStorage.getItem(cacheKey);
      if (!cached) return null;
      var parsed = JSON.parse(cached);
      if (parsed.cache_until && new Date(parsed.cache_until) < new Date()) {
        localStorage.removeItem(cacheKey);
        return null;
      }
      return parsed;
    } catch (e) {
      return null;
    }
  }
  function setCachedData(cacheKey, data) {
    try {
      localStorage.setItem(cacheKey, JSON.stringify(data));
    } catch (e) {
      // LocalStorage書き込み失敗は無視
    }
  }
  function fetchCountryData(apiEndpoint, cacheKey) {
    return fetch(apiEndpoint, {
      method: 'GET',
      headers: {
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      credentials: 'same-origin'
    }).then(function (response) {
      if (!response.ok) throw new Error('HTTP error: ' + response.status);
      return response.json();
    }).then(function (data) {
      setCachedData(cacheKey, data);
      return data;
    }).catch(function () {
      return {
        country_code: 'UNKNOWN',
        allowed: false
      };
    });
  }
  function showContainers(data, containers, targetCountry) {
    if (data.country_code === targetCountry) {
      containers.forEach(function (container) {
        container.style.display = 'block';
      });
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
document.addEventListener('DOMContentLoaded', function () {
  var sidebar = document.querySelector('.p-archiveBody__side');
  var trigger = document.querySelector('.js-sidebar-toggle');
  var overlay = document.querySelector('.js-sidebar-overlay');
  if (!sidebar || !trigger || !overlay) return;
  var closeSidebar = function closeSidebar() {
    sidebar.classList.remove('is-open');
    trigger.classList.remove('is-open');
    trigger.setAttribute('aria-expanded', 'false');
    overlay.classList.remove('is-active');
  };
  var openSidebar = function openSidebar() {
    sidebar.classList.add('is-open');
    trigger.classList.add('is-open');
    trigger.setAttribute('aria-expanded', 'true');
    overlay.classList.add('is-active');
  };
  var mql = window.matchMedia('(max-width: 1279px)');
  var updateVisibility = function updateVisibility() {
    closeSidebar();
  };
  mql.addEventListener('change', updateVisibility);
  trigger.addEventListener('click', function () {
    var isOpen = sidebar.classList.contains('is-open');
    if (isOpen) {
      closeSidebar();
    } else {
      openSidebar();
    }
  });
  overlay.addEventListener('click', closeSidebar);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && sidebar.classList.contains('is-open')) {
      closeSidebar();
    }
  });
});






















































