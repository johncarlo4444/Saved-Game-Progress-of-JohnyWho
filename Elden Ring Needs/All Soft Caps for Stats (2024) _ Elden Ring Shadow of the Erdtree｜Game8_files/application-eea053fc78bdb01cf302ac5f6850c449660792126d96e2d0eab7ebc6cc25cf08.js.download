      var nextStep = document.getElementsByClassName("survey_modal_step".concat(getCurrentStep() + 1))[0];
      currentStep.classList.add('modal_display_none');
      nextStep.classList.remove('modal_display_none');
      setCurrentStep(getCurrentStep() + 1);
    };
    var toggleActivateNextButton = function toggleActivateNextButton() {
      var currentStep = getCurrentStep();
      var nextButton = document.getElementsByClassName("survey_modal_step".concat(currentStep))[0].getElementsByClassName('survey_modal__navigation--next')[0];
      if (shouldActivateNextButton()) {
        nextButton.classList.add('active');
      } else {
        nextButton.classList.remove('active');
      }
    };
    startButton.addEventListener('click', function (e) {
      top.classList.add('modal_display_none');
      step1.classList.remove('modal_display_none');
      setCurrentStep(1);
    });
    Array.from(backButtons).forEach(function (backButton) {
      backButton.addEventListener('click', modalBack);
    });
    for (var i = 0; i < nextButtons.length - 1; ++i) {
      nextButtons[i].addEventListener('click', modalNext);
    }

    // 送信処理、送信ボタン処理
    var shouldActivateSendButton = function shouldActivateSendButton() {
      return document.nps_survey_form.answer.value !== "";
    };
    var toggleActivateSendButton = function toggleActivateSendButton() {
      if (shouldActivateSendButton()) {
        sendButton.classList.add('active');
      } else {
        sendButton.classList.remove('active');
      }
    };
    var submit = function submit() {
      if (!shouldActivateSendButton()) return;
      sendButton.classList.remove('active');
      var inputData = {
        answer: document.nps_survey_form.answer.value,
        advertisement: document.nps_survey_form.advertisement.value,
        quality: document.nps_survey_form.quality.value,
        usability: document.nps_survey_form.usability.value,
        design: document.nps_survey_form.design.value,
        board: document.nps_survey_form.board.value,
        other: document.getElementsByClassName('survey_modal-body__textarea')[0].value,
        archive_id: document.nps_survey_form.archive_id.value,
        game_id: document.nps_survey_form.game_id.value
      };
      fetch('/api/nps_survey', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(inputData)
      }).then(function (res) {
        step6.classList.add('modal_display_none');
        end.classList.remove('modal_display_none');
        document.getElementsByClassName('drawer_survey')[0].remove();
      }).catch(function (err) {
        console.log(err);
        sendButton.classList.add('active');
      });
    };
    sendButton.addEventListener('click', submit);
    var deactivateDetails = function deactivateDetails() {
      var details = document.getElementsByClassName('survey_modal-body__answers-detail-answers-item');
      Array.from(details).forEach(function (detail) {
        detail.classList.remove('active');
      });
    };

    // 可能性周りの制御
    var deactivateAnswers = function deactivateAnswers() {
      var answers = document.getElementsByClassName('survey_modal-body__answers-col');
      Array.from(answers).forEach(function (answer) {
        answer.classList.remove('active');
      });
    };
    var answerEvent = function answerEvent(e) {
      var currentValue = document.nps_survey_form.answer.value;
      if (currentValue === e.currentTarget.getAttribute('value')) {
        // 同じものを選択した場合は可能性もリセットする
        document.nps_survey_form.answer.value = "";
        deactivateAnswers();
      } else {
        document.nps_survey_form.answer.value = e.currentTarget.getAttribute('value');
        deactivateAnswers();
        e.currentTarget.classList.add('active');
      }
      toggleActivateSendButton();
    };
    var answers = document.getElementsByClassName('survey_modal-body__answers-col');
    Array.from(answers).forEach(function (answer) {
      answer.addEventListener('click', answerEvent);
    });

    // 満足度周りの制御
    var getDetails = function getDetails(question_form) {
      return question_form.value.split(',');
    };
    var setDetails = function setDetails(question_form, answers) {
      question_form.value = answers;
    };
    var satisfactions = document.getElementsByClassName('survey_modal-body__answers-detail-answers-item');
    Array.from(satisfactions).forEach(function (satisfaction) {
      satisfaction.addEventListener('click', function (e) {
        var currentSatisfactions = e.currentTarget.parentNode.getElementsByClassName('survey_modal-body__answers-detail-answers-item');
        Array.from(currentSatisfactions).forEach(function (satisfaction) {
          satisfaction.classList.remove('active');
        });
        var question = parseInt(e.currentTarget.getAttribute('question'));
