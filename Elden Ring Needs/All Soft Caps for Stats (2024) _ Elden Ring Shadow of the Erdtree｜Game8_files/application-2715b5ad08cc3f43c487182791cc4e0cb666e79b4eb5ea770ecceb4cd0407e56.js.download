window.addEventListener("DOMContentLoaded", function () {
  window.report_comment = function (id, order_id) {
    if (confirm(I18n.t('js.shared.archive_comments.report.text_1', {
      order_id: order_id
    }))) {
      var token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      fetchJSON("/api/archive_comments/".concat(id, "/report"), {
        method: 'POST',
        referrer: self.location.origin,
        headers: {
          'X-CSRF-Token': token
        }
      }).then(function (res) {
        if (!res.ok) {
          return alert(I18n.t('js.shared.archive_comments.report.alert_2'));
        }
        alert(I18n.t('js.shared.archive_comments.report.alert_1'));
        return location.reload();
      });
    }
  };
  if (!window.forum) {
    window.forum = {};
  }
  window.forum.reportComment = function (id, order_id) {
    if (confirm(I18n.t('js.shared.forum_comment.text_3', {
      order_id: order_id
    }))) {
      var forum_token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      fetchJSON("/api/forum_comments/".concat(id, "/report"), {
        method: 'POST',
        referrer: self.location.origin,
        headers: {
          'X-CSRF-Token': forum_token
        }
      }).then(function (res) {
        console.log(res);
        if (!res.ok) {
          return alert(I18n.t('js.shared.forum_comment.alert_2'));
        }
        alert(I18n.t('js.shared.forum_comment.text_4'));
        return location.reload();
      });
    }
  };
});
