window.addEventListener('DOMContentLoaded', function () {
  var textContents = document.querySelectorAll('.c-commentItem__body p:not(.js-more)');
  textContents.forEach(function (textContent) {
    if (textContent.clientHeight >= 200) {
      var moreButton = document.createElement('div');
      moreButton.classList.add('more-button');
      moreButton.innerHTML = '<span>See more.</span>';
      moreButton.addEventListener('click', function () {
        textContent.classList.add('is-open');
        moreButton.remove();
      });
      textContent.classList.add('js-more');
      textContent.appendChild(moreButton);
    }
  });
});
window.addEventListener('DOMContentLoaded', function () {
  var comment_form_textarea = document.getElementById('js-comment-form-textarea');
  var comment_form_counter = document.getElementById('js-form-word-counter');
  if (!comment_form_textarea || !comment_form_counter) return;
  var comment_length_limit = comment_form_textarea.maxLength;
  var updateRemainingCommentLength = function updateRemainingCommentLength() {
    clearTimeout(comment_form_textarea.dataset.timeout);
    var comment_length = comment_form_textarea.value.length;
    comment_form_textarea.dataset.timeout = setTimeout(function () {
      var comment_remaining_count = comment_length_limit - comment_length;
      comment_form_counter.textContent = comment_remaining_count < 0 ? "".concat(comment_remaining_count, "character over") : "Remaining:".concat(comment_remaining_count, "characters");
      comment_form_counter.classList.toggle('over', comment_remaining_count < 0);
    }, 300);
  };
  updateRemainingCommentLength();
  comment_form_textarea.addEventListener('keyup', function () {
    return updateRemainingCommentLength();
  }, false);
  comment_form_textarea.addEventListener('paste', function () {
    return updateRemainingCommentLength();
  }, false);
});
