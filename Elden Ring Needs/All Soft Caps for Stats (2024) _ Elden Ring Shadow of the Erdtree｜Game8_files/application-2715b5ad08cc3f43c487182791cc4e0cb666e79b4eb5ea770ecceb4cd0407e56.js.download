              var compressedSizeKB = (compressedSize / 1024).toFixed(2);

              // 圧縮前後のサイズ情報を表示
              var sizeInfo = '';
              if (originalSize > compressedSize) {
                sizeInfo = "<div class=\"c-image-info\" style=\"font-size: 12px; color: #666; margin-top: 4px;\">".concat(originalSizeKB, "KB \u2192 ").concat(compressedSizeKB, "KB</div>");
              }
