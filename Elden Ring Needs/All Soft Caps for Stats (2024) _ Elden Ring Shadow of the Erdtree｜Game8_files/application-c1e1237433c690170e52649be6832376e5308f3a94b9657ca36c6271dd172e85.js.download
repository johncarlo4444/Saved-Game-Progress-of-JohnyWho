      id = _JSON$parse.id,
      response_number = _JSON$parse.response_number,
      reply_num = _JSON$parse.reply_num;
    reply_modal_content.innerHTML = '<img src="https://img.game8.jp/232031/4f607d548390ce95fb22a7b12408e510_2016-03-29.gif/thumb?1459236701">';
    // eslint-disable-next-line no-undef
    fetchJSON("/api/archive_comments/receiver_comment/".concat(response_number, "?archive_id=").concat(id, "&anchor_response_number=").concat(reply_num)).then(function (res) {
      if (!res.ok) {
        alert(I18n.t('js.shared.archive_comments.reply.alert_1'));
        return;
      }
      clearReplyModalContent();
      addComment(res.body);
    });
  }, false);
  window.addEventListener('click', function (e) {
    var trigger = e.target.closest('.js-open-child-comment-modal');
    if (!trigger) return;
    var id = trigger.dataset.comment;
    reply_modal_content.innerHTML = '<img src="https://img.game8.jp/232031/4f607d548390ce95fb22a7b12408e510_2016-03-29.gif/thumb?1459236701">';
    fetchJSON("/api/archive_comments/children_comments/".concat(id)).then(function (res) {
      if (!res.ok) {
        alert(I18n.t('js.shared.forum_comment.alert_1'));
        return;
      }
      clearReplyModalContent();
      addComment(res.body);
    });
  }, false);
  function addComment(comments) {
    var ignore_user_ids = Cookies.get("ignore_user_ids") || "";
    comments.forEach(function (comment) {
      var comment_body = comment.body.replace(/((https?)(:\/\/[-_.!~*'()a-zA-Z0-9;/?:@&=+$,%#]+))/, '<a href=\'$1\'>$1</a>');
      comment_body += comment.image_url ? "<img src='".concat(comment.image_url, "'>") : '';
      if (ignore_user_ids.includes(comment.force_trip)) {
        var comment_item = "\n          <div class=\"c-commentItem\">\n            <i class=\"fa fa-ban\">This comment has been blocked.</i>\n          </div>\n        ";
        reply_modal_content.insertAdjacentHTML('beforeend', comment_item);
      } else {
        var _comment_item = "\n          <div class=\"c-commentItem\">\n            <div class='c-commentItem__header'>\n              <span class='c-commentItem__userName'>".concat(comment.response_number, " ").concat(comment.name, "</span>Writing of the\n            </div>\n            <div class=\"c-commentItem__body\">").concat(comment_body, "</div>\n          </div>\n        ");
        reply_modal_content.insertAdjacentHTML('beforeend', _comment_item);
      }
    });
  }
  function clearReplyModalContent() {
    var reply_modal_content = document.getElementById('js-reply-modal-content');
    reply_modal_content.innerHTML = '';
  }
});
window.addEventListener('DOMContentLoaded', function () {
  var comment_length_limit = 500;
  var comment_form_textarea = document.getElementById('js-comment-form-textarea');
  var comment_form_file = document.getElementById('js-comment-upload-file');
  var comment_form_user_id = document.getElementById('js-comment-user-id');
  var comment_form_official_flag = document.getElementById('js-comment-official-flag');
  var comment_form_anonymous = document.getElementById('js-comment-name-anonymous');
  var comment_btn = {
    submit: document.getElementById('js-comment-post'),
    uploading: document.getElementById('js-comment-uploading'),
    success: document.getElementById('js-comment-success')
  };
  var specificProhibitedPhrases = ['Last Updated on', 'Last Update on'];
  window.addEventListener('click', postComment, false);
  function postComment(e) {
    var target = e.target.closest('#js-comment-post');
    if (!target) return;
    var form_textarea_length = comment_form_textarea.value.length;
    if (comment_length_limit < form_textarea_length) {
      alert(I18n.t('js.shared.archive_comments.comment.alert_1'));
      comment_form_textarea.focus();
    } else if (form_textarea_length < 3) {
      alert(I18n.t('js.shared.archive_comments.comment.alert_2'));
      comment_form_textarea.focus();
    } else if (includeProhibitedWord() || includeSpecificProhibitedPhrases()) {
      alert(I18n.t('js.shared.archive_comments.comment.alert_4'));
      comment_form_textarea.focus();
    } else {
      comment_btn.submit.style.display = 'none';
      comment_btn.uploading.style.display = 'block';
      var formData = new FormData();
      // 画像が添付されていたら
      // 圧縮済みBlobがあればそちらを使用、なければ元のファイルを使用
      var compressedBlob = window.getCompressedImageBlob && window.getCompressedImageBlob();
      if (compressedBlob) {
        formData.append('archive_comment[upload_file]', compressedBlob, 'comment_image.jpg');
      } else if (comment_form_file.files[0]) {
        // フォールバック: 圧縮がない場合は元のファイルを使用（後方互換性のため）
        formData.append('archive_comment[upload_file]', comment_form_file.files[0]);
      }
      // ログインしていて、名無しオプションがなければuser_idを送信
      if (comment_form_user_id && comment_form_user_id.value && comment_form_anonymous && !comment_form_anonymous.checked) {
        formData.append('archive_comment[user_id]', comment_form_user_id.value);
      }
      // 匿名投稿オプションがチェックされていれば送信
      if (comment_form_anonymous && comment_form_anonymous.checked) {
        formData.append('archive_comment[is_not_login_user]', '1');
      }
      // 公式としてコメントするオプションがあれば
      if (comment_form_official_flag && comment_form_official_flag.checked) {
        formData.append('archive_comment[official_user_id]', comment_form_official_flag.value);
      }
      formData.append('archive_comment[archive_id]', gon.archive_id);
      formData.append('archive_comment[body]', comment_form_textarea.value);
      var token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      window.removeEventListener('click', postComment, false);
      fetchJSON('/api/archive_comments', {
        method: 'POST',
        referrer: self.location.origin,
        headers: {
          'X-CSRF-Token': token
        },
        body: formData
      }).then(function (res) {
        if (res.ok) {
          comment_btn.uploading.style.display = 'none';
          comment_btn.success.style.display = 'display';

          // 非ログイン時にメンバーシップモーダル表示フラグを設定
          var isLoggedIn = comment_form_user_id && comment_form_user_id.value;
          if (!isLoggedIn) {
            sessionStorage.setItem('showMembershipModal', 'true');
          }
          window.location.reload();
        } else {
          var text = I18n.t('js.shared.archive_comments.comment.text_1');
          if (res.status === 422) {
            text = I18n.t('js.shared.archive_comments.comment.text_1');
          } else if (res.status === 406) {
            text = res.body && res.body.body && res.body.body[0] || text;
          } else if (res.status === 403) {
            text = I18n.t('js.shared.archive_comments.comment.text_2');
          }
          alert(text);
          comment_btn.uploading.style.display = 'none';
          comment_btn.submit.style.display = 'block';
          window.addEventListener('click', postComment, false);
        }
      });
    }
  }
  function includeProhibitedWord() {
    var _gon = gon,
      prohibited_words = _gon.prohibited_words;
    return prohibited_words.some(function (word) {
      return comment_form_textarea.value.includes(word);
    });
  }
  function includeSpecificProhibitedPhrases() {
    return specificProhibitedPhrases.some(function (phrase) {
      return comment_form_textarea.value.toLowerCase().includes(phrase.toLowerCase());
    });
  }

  // ページロード時にメンバーシップモーダル表示フラグをチェック
  if (sessionStorage.getItem('showMembershipModal') === 'true') {
    sessionStorage.removeItem('showMembershipModal');
    if (typeof window.openMembershipModal === 'function') {
      setTimeout(function () {
        window.openMembershipModal('archive_comment_notification',
        // utmMedium
        'user_registration_flow',
        // trackNierKeyword
        'archive_comment_posted',
        // trackNierValue
        function () {},
        // onClose (何もしない)
        'notification',
        // contentType
        true // allowGuest
        );
      }, 1000);
    }
  }
});
