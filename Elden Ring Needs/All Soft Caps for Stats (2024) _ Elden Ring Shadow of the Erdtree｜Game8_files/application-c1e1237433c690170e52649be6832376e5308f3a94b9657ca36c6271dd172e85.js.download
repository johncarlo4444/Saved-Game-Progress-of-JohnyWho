window.addEventListener("DOMContentLoaded", function () {
  var formDummy = document.getElementById("js-commentFormDumy");
  var formMain = document.getElementById("js-commentFormMain");
  if (!formDummy || !formMain) return;
  formDummy.addEventListener("click", function () {
    formDummy.style.display = "none";
    formMain.style.display = "block";
    var textarea = document.getElementById("js-comment-form-textarea");
    textarea.focus();
  });
});
window.addEventListener('DOMContentLoaded', function () {
  window.addEventListener('click', function (e) {
    var trigger = e.target.closest('.js-insert-anchor');
    if (!trigger) return;
    var responseNumber = trigger.dataset.responseNumber;
    var form_area = document.getElementById('js-reply-target');
    if (form_area) {
      window.scrollTo({
        left: 0,
        top: form_area.offsetTop,
        behavior: 'smooth'
      });
    }
    var commentFormDumy = document.getElementById('js-commentFormDumy');
    if (commentFormDumy) {
      commentFormDumy.style.display = 'none';
      document.getElementById('js-commentFormMain').style.display = 'block';
    }
    var comment_form_textarea = document.getElementById("js-comment-form-textarea");
    if (!comment_form_textarea) return;
    if (comment_form_textarea.value.includes(">>[".concat(responseNumber, "]"))) return;
    if (comment_form_textarea.value.split("\n")[0].includes(">>[")) {
      comment_form_textarea.value = ">>[".concat(responseNumber, "]\n").concat(comment_form_textarea.value);
    } else {
      comment_form_textarea.value = ">>[".concat(responseNumber, "] ").concat(comment_form_textarea.value);
    }
  });
});
