window.addEventListener('DOMContentLoaded', function () {
  window.addEventListener('click', toggleCommentFav, false);
  function toggleCommentFav(e) {
    var target = e.target.closest('.js-fav-comment-trigger');
    if (!target) return;
    var active_class_name = 'is-active';
    var _JSON$parse = JSON.parse(target.dataset.comment),
      id = _JSON$parse.id,
      is_user_present = _JSON$parse.is_user_present;
    if (!is_user_present) {
      return MicroModal.show('js-register-modal', {
        disableScroll: true,
        disableFocus: true,
        awaitOpenAnimation: true,
        awaitCloseAnimation: true
      });
    }
    var token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
    fetchJSON("/api/archive_comments/".concat(id, "/favorite.json"), {
      method: 'POST',
      referrer: self.location.origin,
      headers: {
        'X-CSRF-Token': token
      }
    }).then(function (res) {
      if (!res.ok) {
        alert('コメントの保存に失敗しました');
        return;
      }
      var _res$body = res.body,
        is_favorite = _res$body.is_favorite,
        is_first_comment = _res$body.is_first_comment,
        comment = _res$body.comment;
      var fav_icon = target.getElementsByClassName('js-comment-fav-icon')[0];
      var fav_counter = target.getElementsByClassName('js-comment-fav-count')[0];
      fav_icon.classList.toggle(active_class_name, is_favorite);
      fav_counter.textContent = comment.favorite_count > 0 ? comment.favorite_count : '';
      if (is_favorite && is_first_comment) {
        if (window.confirm('コメントを保存しました。マイページから確認できます。マイページに移動しますか？')) {
          return location.href = '/i/mypage';
        }
      }
    });
  }
});
window.addEventListener('DOMContentLoaded', function () {
  var feedBackText = document.querySelector('.a-afterFeedback');
  var badButton = document.querySelector('.a-feedback__badButton');
  var feedBackContent = document.querySelector('.a-feedback');
  var goodButton = document.querySelector('.a-feedback__goodButton');
  if (badButton) {
    badButton.addEventListener('click', function () {
      feedBackText.style.display = 'block';
      feedBackContent.style.display = 'none';
    });
  }
  if (goodButton) {
    goodButton.addEventListener('click', function () {
      feedBackText.style.display = 'block';
      feedBackContent.style.display = 'none';
    });
  }
});
